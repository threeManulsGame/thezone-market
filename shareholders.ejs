<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Акционеры >1%</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-dark text-light">
  <div class="container mt-4">
    <h2>Держатели более 1% акций</h2>
    <p>Всего акций в обращении: <%= totalShares.toLocaleString() %></p>
    <a href="/" class="btn btn-secondary mb-3">На рынок</a>
    <table class="table table-dark table-striped">
      <thead><tr><th>Имя</th><th>Акции</th><th>Доля</th></tr></thead>
      <tbody>
        <% shareholders.forEach(s => { %>
          <tr>
            <td><%= s.username %></td>
            <td><%= s.share_balance.toLocaleString() %></td>
            <td><%= ((s.share_balance / totalShares)*100).toFixed(2) %>%</td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</body>
</html>