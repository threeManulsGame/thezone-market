<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>The Zone Market</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <script src="https://cdn.jsdelivr.net/npm/lightweight-charts@3.8.0/dist/lightweight-charts.standalone.production.js"></script>
  <style>
    #chart-container { width: 100%; height: 500px; margin-top: 20px; background: #1e1e1e; border-radius: 8px; overflow: hidden; }
    .chart-controls { display: flex; gap: 10px; align-items: center; margin-top: 10px; flex-wrap: wrap; }
    .chart-controls select { background: #2c2c2c; color: #eee; border: 1px solid #555; border-radius: 4px; padding: 4px 8px; }
    .debug-info { font-size: 0.85rem; color: #aaa; margin-top: 5px; }
    .error-message { color: #ff6b6b; margin-top: 10px; }
    .market-closed { background: #dc3545; color: white; padding: 5px 10px; border-radius: 4px; }
    .market-open { background: #198754; color: white; padding: 5px 10px; border-radius: 4px; }
  </style>
</head>
<body class="bg-dark text-light">
  <nav class="navbar navbar-expand-lg navbar-dark bg-black mb-4">
    <div class="container">
      <a class="navbar-brand" href="/">💎 The Zone</a>
      <div class="navbar-nav ms-auto">
        <span class="nav-link">Привет, <%= user.username %></span>
        <a class="nav-link" href="/shareholders">Акционеры >1%</a>
        <% if (isAdmin) { %><a class="nav-link" href="/admin">⚙️ Админ</a><% } %>
        <a class="nav-link" href="/logout">Выход</a>
      </div>
    </div>
  </nav>
  <div class="container">
    <div class="row mb-4">
      <div class="col-md-4">
        <div class="card bg-secondary text-light">
          <div class="card-body">
            <h5>Ваш баланс</h5>
            <p>💎 <%= user.diamond_balance.toLocaleString() %> алмазов</p>
            <p>📈 <%= user.share_balance.toLocaleString() %> акций</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card bg-secondary text-light">
          <div class="card-body text-center">
            <h3>Цена акции</h3>
            <h1 class="display-4">
              <span style="color: <%= priceChange > 0 ? '#26a69a' : (priceChange < 0 ? '#ef5350' : 'inherit') %>">
                <%= price %> 💎
              </span>
              <small style="font-size: 0.5em; color: <%= priceChange >=0 ? '#26a69a' : '#ef5350' %>">
                <%= priceChange > 0 ? '+' : '' %><%= priceChange.toFixed(4) %>
              </small>
            </h1>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card bg-secondary text-light">
          <div class="card-body">
            <h5>Пул ликвидности</h5>
            <p>Алмазов: <%= pool.diamonds.toLocaleString() %></p>
            <p>Акций: <%= pool.shares.toLocaleString() %></p>
            <p>Статус: 
              <% if (marketOpen) { %>
                <span class="market-open">Открыт</span>
              <% } else { %>
                <span class="market-closed">Закрыт</span>
              <% } %>
            </p>
          </div>
        </div>
      </div>
    </div>

    <% if (!marketOpen) { %>
      <div class="alert alert-warning">Рынок закрыт. Торги будут доступны в часы работы (7:00–19:00 GMT+3).</div>
    <% } %>

    <div class="row">
      <div class="col-md-6">
        <h4>Купить / Продать</h4>
        <% if (marketOpen) { %>
          <form action="/buy" method="post" class="mb-2">
            <div class="input-group">
              <input type="number" step="any" name="shares" class="form-control" placeholder="Количество акций" required>
              <button class="btn btn-success">Купить</button>
            </div>
          </form>
          <form action="/sell" method="post">
            <div class="input-group">
              <input type="number" step="any" name="shares" class="form-control" placeholder="Количество акций" required>
              <button class="btn btn-danger">Продать</button>
            </div>
          </form>
        <% } else { %>
          <p class="text-muted">Торги приостановлены.</p>
        <% } %>
      </div>
      <div class="col-md-6">
        <h4>Новости</h4>
        <ul class="list-group">
          <% news.forEach(n => { %>
            <li class="list-group-item bg-dark text-light border-secondary">
              <strong><%= n.title %></strong> <span class="badge bg-<%= n.impact >=0 ? 'success' : 'danger' %>"><%= n.impact >0 ? '+' : '' %><%= n.impact.toFixed(2) %>%</span>
              <% if (!n.applied) { %><span class="badge bg-warning">Будет применено при открытии</span><% } %>
              <br><small><%= n.body %></small>
              <br><small class="text-muted"><%= new Date(n.created_at).toLocaleString() %></small>
            </li>
          <% }) %>
        </ul>
      </div>
    </div>

    <h4 class="mt-5">График цены</h4>
    <div class="chart-controls">
      <label>Интервал свечей:</label>
      <select id="chartInterval">
        <option value="5m">5 мин</option>
        <option value="15m">15 мин</option>
        <option value="30m">30 мин</option>
        <option value="1h">1 час</option>
        <option value="4h">4 часа</option>
        <option value="12h">12 часов</option>
        <option value="1d">День</option>
      </select>
      <span id="chartStatus" class="text-muted ms-2">Загрузка...</span>
    </div>
    <div id="chart-container"></div>
    <div id="debugInfo" class="debug-info"></div>
    <div id="chart-error" class="error-message"></div>
  </div>

  <script>
    (function() {
      const container = document.getElementById('chart-container');
      const intervalSelect = document.getElementById('chartInterval');
      const statusEl = document.getElementById('chartStatus');
      const debugEl = document.getElementById('debugInfo');
      const errorEl = document.getElementById('chart-error');
      let chart = null, candleSeries = null;

      function debug(msg) {
        debugEl.textContent = msg;
        console.log('[Chart]', msg);
      }

      function createChart() {
        try {
          if (chart) { chart.remove(); chart = null; candleSeries = null; }
          const interval = intervalSelect.value;
          const width = container.clientWidth || 800;
          const height = container.clientHeight || 500;

          if (typeof LightweightCharts.createChart !== 'function') {
            throw new Error('Библиотека графиков повреждена.');
          }
          chart = LightweightCharts.createChart(container, {
            width, height,
            layout: { backgroundColor: '#1e1e1e', textColor: '#d1d4dc' },
            grid: { vertLines: { color: '#2B2B43' }, horzLines: { color: '#2B2B43' } },
            crosshair: { mode: LightweightCharts.CrosshairMode.Normal },
            timeScale: { timeVisible: true, secondsVisible: false },
          });

          statusEl.textContent = 'Загрузка данных...';
          errorEl.textContent = '';
          debug('Загрузка данных...');

          fetch(`/api/price-history?type=candle&interval=${interval}`)
            .then(r => { if (!r.ok) throw new Error('Сервер вернул ' + r.status); return r.json(); })
            .then(json => {
              let data = json.data || [];
              // Фильтруем невалидные значения
              data = data.filter(d =>
                d.time != null &&
                d.open != null && isFinite(d.open) &&
                d.high != null && isFinite(d.high) &&
                d.low != null && isFinite(d.low) &&
                d.close != null && isFinite(d.close)
              );
              const count = data.length;
              debug(`Получено ${count} свечей`);
              statusEl.textContent = count === 0 ? 'Нет данных за выбранный период.' : '';

              candleSeries = chart.addCandlestickSeries({
                upColor: '#26a69a', downColor: '#ef5350',
                borderDownColor: '#ef5350', borderUpColor: '#26a69a',
                wickDownColor: '#ef5350', wickUpColor: '#26a69a',
              });
              candleSeries.setData(data);
            })
            .catch(err => {
              console.error(err);
              errorEl.textContent = 'Ошибка загрузки данных: ' + err.message;
              statusEl.textContent = 'Ошибка';
              debug('Ошибка: ' + err.message);
            });
        } catch (e) {
          console.error(e);
          errorEl.textContent = 'Ошибка создания графика: ' + e.message;
          debug('Критическая ошибка: ' + e.message);
        }
      }

      function resizeChart() {
        if (chart) chart.resize(container.clientWidth || 800, container.clientHeight || 500);
      }

      intervalSelect.addEventListener('change', createChart);
      window.addEventListener('resize', resizeChart);

      createChart();

      // Автообновление
      setInterval(() => {
        if (!chart || !candleSeries) return;
        const interval = intervalSelect.value;
        fetch(`/api/price-history?type=candle&interval=${interval}`)
          .then(r => r.json())
          .then(json => {
            let data = json.data || [];
            data = data.filter(d =>
              d.time != null &&
              d.open != null && isFinite(d.open) &&
              d.high != null && isFinite(d.high) &&
              d.low != null && isFinite(d.low) &&
              d.close != null && isFinite(d.close)
            );
            candleSeries.setData(data);
            debug(`Автообновление: ${data.length} свечей`);
            statusEl.textContent = '';
            errorEl.textContent = '';
          })
          .catch(e => console.error('Auto-update error:', e));
      }, 10000);
    })();
  </script>
</body>
</html>
