<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>The Zone Market</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <meta name="viewport" content="width=device-width, initial-scale=1">
</head>
<body class="bg-dark text-light">
  <nav class="navbar navbar-expand-lg navbar-dark bg-black mb-4">
    <div class="container">
      <a class="navbar-brand" href="/">💎 The Zone</a>
      <div class="navbar-nav ms-auto">
        <span class="nav-link">Привет, <%= user.username %></span>
        <a class="nav-link" href="/shareholders">Акционеры >1%</a>
        <% if (isAdmin) { %><a class="nav-link" href="/admin">⚙️ Админ</a><% } %>
        <a class="nav-link" href="/logout">Выход</a>
      </div>
    </div>
  </nav>
  <div class="container">
    <div class="row mb-4">
      <div class="col-md-4">
        <div class="card bg-secondary text-light">
          <div class="card-body">
            <h5>Ваш баланс</h5>
            <p>💎 <%= user.diamond_balance.toLocaleString() %> алмазов</p>
            <p>📈 <%= user.share_balance.toLocaleString() %> акций</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card bg-secondary text-light">
          <div class="card-body text-center">
            <h3>Цена акции</h3>
            <h1 class="display-4"><%= price %> 💎</h1>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card bg-secondary text-light">
          <div class="card-body">
            <h5>Пул ликвидности</h5>
            <p>Алмазов: <%= pool.diamonds.toLocaleString() %></p>
            <p>Акций: <%= pool.shares.toLocaleString() %></p>
          </div>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-md-6">
        <h4>Купить / Продать</h4>
        <form action="/buy" method="post" class="mb-2">
          <div class="input-group">
            <input type="number" step="any" name="shares" class="form-control" placeholder="Количество акций" required>
            <button class="btn btn-success">Купить</button>
          </div>
        </form>
        <form action="/sell" method="post">
          <div class="input-group">
            <input type="number" step="any" name="shares" class="form-control" placeholder="Количество акций" required>
            <button class="btn btn-danger">Продать</button>
          </div>
        </form>
      </div>
      <div class="col-md-6">
        <h4>Новости</h4>
        <ul class="list-group">
          <% news.forEach(n => { %>
            <li class="list-group-item bg-dark text-light border-secondary">
              <strong><%= n.title %></strong> <span class="badge bg-<%= n.impact >=0 ? 'success' : 'danger' %>"><%= n.impact >0 ? '+' : '' %><%= n.impact %>%</span>
              <br><small><%= n.body %></small>
              <br><small class="text-muted"><%= new Date(n.created_at).toLocaleString() %></small>
            </li>
          <% }) %>
        </ul>
      </div>
    </div>
  </div>
</body>
</html>